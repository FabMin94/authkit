@baseUrl = http://localhost:8000
@token = YOUR.TOKEN.HERE

GET {{baseUrl}}/health

###

POST {{baseUrl}}/api/v1/auth/register HTTP/1.1
content-type: application/json

{
    "email": "fake@user.com",
    "password": "verysecret"
}

